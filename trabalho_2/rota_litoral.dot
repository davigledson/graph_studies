    "Natal" -- "Mossoro" [label="277km" color="#000000" penwidth=0.8 fontcolor="#000000" fontsize=50]
    "Extremoz" -- "Touros" [label="80km" color="#000000" penwidth=0.8 fontcolor="#000000" fontsize=50]
    "Extremoz" -- "Mossoro" [label="250km" color="#000000" penwidth=0.8 fontcolor="#000000" fontsize=50]
    "Touros" -- "Sao Miguel Gostoso" [label="25km" color="#C0392B" penwidth=3.0 fontcolor="#C0392B" fontsize=70]
