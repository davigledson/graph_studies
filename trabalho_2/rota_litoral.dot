graph rota_litoral {
    graph [
        rankdir=LR
        bgcolor="#F5F7F8"
        label="Rota Litoranea  até 2 Porto das Dunas\n741 km  •  9h 16min "
        fontsize=100
        labelloc=t
        fontcolor="#173F48"
        fontname="Helvetica"
        pad=0.8
        nodesep=0.4
        ranksep=0.6
        splines=true
        size="13,7"
        ratio=fill
    ]
    node [
        shape=box
        style="filled,rounded"
        fontname="Helvetica"
        fontsize=13
        fontcolor="#173F48"
        fillcolor="#DDE8EA"
        color="#8AB4BC"
        penwidth=1.2
        width=1.1
        height=0.42
        margin=0.12
    ]
    edge [
        fontname="Helvetica"
        fontsize=9
        fontcolor="#8AB4BC"
        color="#B0CDD2"
        penwidth=1.0
        arrowsize=0
    ]

    "Recife" [fillcolor="#B8D4D8" color="#4A8A96" penwidth=2.5 fontsize=60 fontcolor="#173F48"]
    "Olinda" [fillcolor="#173F48" color="#173F48" fontsize=60  fontcolor="#FFFFFF"]
    "Paulista" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Goiana" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Pitimbu" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Conde" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Joao Pessoa" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Cabedelo" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Baia Formosa" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Pipa" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60  penwidth=1.8 fontcolor="#173F48"]
    "Nisia Floresta" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Natal" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Extremoz" [fillcolor="#173F48" color="#173F48"fontsize=60 fontcolor="#FFFFFF"]
    "Touros" [fillcolor="#B8D4D8" color="#4A8A96"fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Sao Miguel Gostoso" [fillcolor="#B8D4D8" fontsize=60 color="#4A8A96" penwidth=1.8 fontcolor="#173F48"]
    "Mossoro" [fillcolor="#173F48" color="#173F48" fontsize=60 fontcolor="#FFFFFF"]
    "Tibau" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Icapui" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Aracati" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Beberibe" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Aquiraz" [fillcolor="#B8D4D8" color="#4A8A96" fontsize=60 penwidth=1.8 fontcolor="#173F48"]
    "Porto das Dunas" [fillcolor="#C0392B" color="#922B21" fontsize=60 penwidth=2.5 fontsize=60 fontcolor="#FFFFFF" shape=box]

    "Recife" -- "Olinda" [label="5km" color="#000000" penwidth=0.8 fontcolor="#000000" fontsize=50]
