graph G {

layout="circo";

    // Grafo
    subgraph cluster_grafo {
        label="Grafo"
        A -- B
        A -- C
        B -- C
        C -- D
    }

    // Matriz de adjacência
    matriz [shape=plaintext label=<
    <table border="1" cellborder="1" cellspacing="0">
        <tr>
            <td></td><td>A</td><td>B</td><td>C</td><td>D</td>
        </tr>
        <tr>
            <td>A</td><td>0</td><td>1</td><td>1</td><td>0</td>
        </tr>
        <tr>
            <td>B</td><td>1</td><td>0</td><td>1</td><td>0</td>
        </tr>
        <tr>
            <td>C</td><td>1</td><td>1</td><td>0</td><td>1</td>
        </tr>
        <tr>
            <td>D</td><td>0</td><td>0</td><td>1</td><td>0</td>
        </tr>
    </table>
    >];
}