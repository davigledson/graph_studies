graph GrafoComDual {

    layout=neato
    node [style=filled]

    // Grafo original
    A [fillcolor=lightblue, pos="0,2!"]
    B [fillcolor=lightblue, pos="2,2!"]
    C [fillcolor=lightblue, pos="2,0!"]
    D [fillcolor=lightblue, pos="0,0!"]

    A -- B
    B -- C
    C -- D
    D -- A
    A -- C

    // Vértices do grafo dual (faces)
    F1 [fillcolor=lightcoral, pos="1.5,1.3!"];
    F2 [fillcolor=lightcoral, pos="0.6,0.7!"];
    F3 [fillcolor=lightcoral, pos="3,1!"];

    // Arestas do dual
    F1 -- F2 [color=red, style=dashed]; 
    F1 -- F3 [color=red, style=dashed];
    F2 -- F3 [color=red, style=dashed];

}